# E-Governance Platform - Environment variables
# Update the values below as needed. Do not commit real passwords to git.

# ----- Usually keep as-is (Docker default) -----
GATEWAY_PORT=8000
CITIZEN_SERVICE_URL=http://citizen-service:8001
NOTIFICATION_SERVICE_URL=http://notification-service:8002
DOCUMENT_SERVICE_URL=http://document-service:8003
DATABASE_URL=postgresql+asyncpg://egov:egov_secret@postgres:5432/egov
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO

# ----- Update for production -----
# Use a long random string or your own phrase. Same value must be set for api-gateway and citizen-service in Docker.
JWT_SECRET_KEY=change-this-secret-key-in-production
# ----- Email (optional): fill these to enable status-change and welcome emails -----
# Leave SMTP_USER empty to disable email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dara.saikalyan74@gmail.com
SMTP_PASSWORD=mejnbgrjmmfuchkg
EMAIL_FROM=dara.saikalyan74@gmail.com
